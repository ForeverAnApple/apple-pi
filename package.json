{
  "name": "apple-pi",
  "version": "0.1.0",
  "description": "Opinionated pi extension — lightweight in-process subagent system",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ForeverAnApple/apple-pi.git"
  },
  "homepage": "https://github.com/ForeverAnApple/apple-pi",
  "bugs": {
    "url": "https://github.com/ForeverAnApple/apple-pi/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "subagents",
    "agents",
    "ai"
  ],
  "files": [
    "*.ts",
    "!*.test.ts",
    "agents/",
    "README.md"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "changeset": "npx changeset",
    "changeset:version": "npx changeset version",
    "changeset:release": "npx changeset publish"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0"
  }
}
