{
  "name": "apple-pi",
  "version": "0.1.0",
  "description": "Opinionated pi extension — lightweight in-process subagent system",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "subagents",
    "agents",
    "ai"
  ],
  "files": [
    "*.ts",
    "!*.test.ts",
    "agents/",
    "README.md"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test test/*.test.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
